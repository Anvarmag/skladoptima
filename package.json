{
  "name": "sklad-optima",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w api\" \"npm run dev -w web\"",
    "build": "npm run build -w api && npm run build -w web",
    "prisma:generate": "npm run db:generate -w api",
    "prisma:migrate": "npm run db:migrate -w api",
    "prisma:seed": "npm run db:seed -w api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
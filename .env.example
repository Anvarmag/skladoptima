# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sklad_optima

# ─── API ───────────────────────────────────────────────────────────────────────
# Full connection string used by Prisma
DATABASE_URL="postgresql://admin:CHANGE_ME_STRONG_PASSWORD@postgres:5432/sklad_optima?schema=public"

# JWT – MUST be a long random string, e.g.: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_JWT_SECRET_MIN_32_CHARS"

# Default admin credentials (changed on first login in prod)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"

# Port the NestJS API listens on (inside Docker)
PORT=3000

# Allowed CORS origin (your domain or VPS IP)
CORS_ORIGIN="https://yourdomain.com"

# ─── WEB (frontend – baked into build, NOT a secret) ──────────────────────────
# If nginx proxies /api internally, leave empty ("").
# If you expose the API on a separate subdomain, set the full URL here.
VITE_API_URL=""

# ─── Marketplace API keys (stored in DB via Settings page, NOT in .env) ───────
# These are only here as a reminder. Enter them via the Settings UI in the app.
# WB_API_KEY=
# OZON_CLIENT_ID=
# OZON_API_KEY=

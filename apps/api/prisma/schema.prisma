// -------------------------------------------------------------------
// 4a. ORDERS DOMAIN (TASK_ORDERS_1) — см. 10-orders system-analytics
// §8/§9/§13/§15.
//
// Доменная модель заказов отдельная от legacy `MarketplaceOrder`, чтобы:
//   1. Не сломать существующий sync.service (он продолжает писать в
//      `MarketplaceOrder` — переключение на доменную модель будет в
//      следующих TASK_ORDERS_2/3).
//   2. Поддержать ingestion с провенансом (`marketplaceAccountId`,
//      `syncRunId`, `externalEventId`) и многострочными `OrderItem`,
//      чего у плоской `MarketplaceOrder` нет.
//   3. Различать FBS и FBO в data-model явно через `fulfillmentMode`,
//      `affectsStock`, `stockEffectStatus` (§9 шаги 5-9).
// -------------------------------------------------------------------

/// Header заказа маркетплейса. Уникален в рамках (tenant, marketplace,
/// marketplace_order_id). `marketplaceAccountId` обязателен — мы всегда
/// знаем, какой аккаунт принёс заказ. `syncRunId` опционален: позволяет
/// восстановить связку с конкретным `SyncRun` без обращения к сырым
/// логам (§12 DoD), но для исторических/manual reprocess может быть NULL.
///
/// `internalStatus` — наш собственный lifecycle (см. §13). `externalStatus`
/// — последний raw статус от маркетплейса (включая PACKED/SHIPPED, которые
/// не создают внутренний переход в MVP).
///
/// `affectsStock` — материализованный флаг "влияет ли заказ на остатки"
/// (true для FBS-c-warehouse, false для FBO/display-only). Отделён от
/// `stockEffectStatus`, потому что заказ может быть affects_stock=true,
/// но фактически stockEffectStatus=PENDING (warehouse scope ещё не
/// определён) или FAILED (inventory отказал).
///
/// `warehouseId` nullable: для FBS-заказов он определяется warehouse
/// scope матчинга, для FBO/UNRESOLVED — остаётся NULL.
model Order {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  marketplace          MarketplaceType
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)

  // Связь с конкретным sync run, который доставил последнее событие
  // заказа. SET NULL — удаление run'а не теряет сам заказ.
  syncRunId String?
  syncRun   SyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  marketplaceOrderId String @db.VarChar(128)

  fulfillmentMode OrderFulfillmentMode

  externalStatus String?             @db.VarChar(128)
  internalStatus OrderInternalStatus @default(IMPORTED)

  affectsStock      Boolean                @default(false)
  stockEffectStatus OrderStockEffectStatus @default(NOT_REQUIRED)

  // Warehouse scope для FBS effects. Для FBO/UNRESOLVED — NULL.
  // SET NULL: архивация склада не должна осиротить или удалить заказ.
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  // Время создания у маркетплейса (нормализованное), отдельно от нашего
  // `createdAt` (когда мы записали заказ).
  orderCreatedAt DateTime?
  // Время последней успешной обработки order event (см. §9 шаг 4 для
  // out-of-order detection).
  processedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items  OrderItem[]
  events OrderEvent[]

  // §8: уникальность в рамках tenant/marketplace/external id. Account
  // НЕ входит в ключ сознательно: один и тот же заказ не может
  // принадлежать двум разным аккаунтам того же маркетплейса.
  @@unique([tenantId, marketplace, marketplaceOrderId])
  // UI: списки заказов с фильтрами по статусу и времени.
  @@index([tenantId, internalStatus, createdAt])
  @@index([tenantId, marketplaceAccountId, createdAt])
  // Диагностика stuck pending stock-effects (§19 alerts).
  @@index([tenantId, stockEffectStatus, createdAt])
  // Поиск всех заказов конкретного sync run (диагностика incident'ов).
  @@index([syncRunId])
}

/// Строки заказа. У одного `Order` может быть N items (§14). `productId`
/// и `warehouseId` nullable: мы НЕ блокируем сохранение заказа из-за
/// отсутствия маппинга — вместо этого item помечается `UNMATCHED` и
/// исключается из stock-effect, пока не будет resolved.
model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  sku  String? @db.VarChar(128)
  name String? @db.VarChar(255)

  matchStatus OrderItemMatchStatus @default(UNMATCHED)

  // Warehouse scope именно для этой строки (актуально, если разные
  // позиции FBS-заказа лежат на разных складах). NULL — пока не
  // определён.
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  quantity Int
  // PostgreSQL NUMERIC(12,2) — точное представление цен без float-дрифта.
  price    Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Диагностика: список unresolved items по tenant'у (§19 alerts:
  // unmatched_sku_orders).
  @@index([orderId])
  @@index([orderId, matchStatus])
  @@index([productId])
}

/// Append-only журнал событий заказа: provenance каждого внешнего
/// события, маппинг статусов, side-effects, идемпотентные ignores и
/// failures. См. §15.
///
/// `externalEventId` — стабильный идентификатор события маркетплейса
/// (например, version-stamp postingа). UNIQUE(tenantId,
/// marketplaceAccountId, externalEventId) реализует идемпотентность на
/// уровне БД: повторная доставка того же события не создаст вторую
/// запись и, как следствие, не запустит повторный reserve/deduct
/// (§9 шаг 3, §12 DoD).
///
/// Account входит в ключ, потому что один и тот же external_event_id
/// в разных аккаунтах семантически разный (разные интеграционные
/// каналы). Это согласовано с pattern'ом `SyncRunItem.externalEventId`.
model OrderEvent {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)

  externalEventId String         @db.VarChar(128)
  eventType       OrderEventType

  payload   Json?
  createdAt DateTime @default(now())

  // §8: DB-level idempotency. Повторный event с тем же external id
  // в рамках того же account отклоняется на уровне UNIQUE constraint;
  // application слой ловит ошибку и пишет один `DUPLICATE_IGNORED`.
  @@unique([tenantId, marketplaceAccountId, externalEventId])
  // Order timeline (UI /orders/:id/timeline) — последние события заказа.
  @@index([orderId, createdAt])
  // Диагностика по типам событий внутри tenant (§19 dashboards:
  // duplicate/out-of-order monitor).
  @@index([tenantId, eventType, createdAt])
}

model MarketplaceReport {
  id          String          @id @default(uuid())
  reportId    String
  marketplace MarketplaceType
  periodStart DateTime
  periodEnd   DateTime

  salesAmount      Float @default(0)
  returnsAmount    Float @default(0)
  commissionAmount Float @default(0)
  logisticsAmount  Float @default(0)
  storageAmount    Float @default(0)
  otherDeductions  Float @default(0)
  netToPay         Float @default(0)

  rawJson String?

  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reportId])
}


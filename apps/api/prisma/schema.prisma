generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------
// ENUMS
// -------------------------------------------------------------------

enum TaxSystem {
  USN_6
  USN_15
  OSNO
  NPD
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum AccessState {
  EARLY_ACCESS
  TRIAL_ACTIVE
  TRIAL_EXPIRED
  ACTIVE_PAID
  SUSPENDED
  CLOSED
}

enum MarketplaceType {
  WB
  OZON
}

enum ActionType {
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STOCK_ADJUSTED
  ORDER_DEDUCTED
}

// Auth enums
enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
  DELETED
}

enum AuthSessionStatus {
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED
  COMPROMISED
}

enum ChallengeStatus {
  PENDING
  USED
  EXPIRED
  CANCELLED
}

enum AuthProvider {
  LOCAL
  TELEGRAM
  GOOGLE
  YANDEX
  SMS
}

// -------------------------------------------------------------------
// 1. ПОЛЬЗОВАТЕЛИ И AUTH
// -------------------------------------------------------------------

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // Telegram — временно остаётся здесь, будет вынесено в AuthIdentity
  telegramId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Membership[]
  auditLogs          AuditLog[]
  authSessions       AuthSession[]
  emailVerifications EmailVerificationChallenge[]
  passwordResets     PasswordResetChallenge[]
  preferences        UserPreference?
  authIdentities     AuthIdentity[]
}

// Серверные сессии с refresh token rotation и reuse detection
model AuthSession {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String            @unique
  status           AuthSessionStatus @default(ACTIVE)
  ip               String?
  userAgent        String?
  lastSeenAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, status])
}

// Одноразовые токены подтверждения email (хранится hash, не plaintext)
model EmailVerificationChallenge {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailSnapshot String
  tokenHash     String          @unique
  status        ChallengeStatus @default(PENDING)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
}

// Одноразовые токены сброса пароля (хранится hash, не plaintext)
model PasswordResetChallenge {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String          @unique
  status    ChallengeStatus @default(PENDING)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

// Пользовательские настройки — последний активный тенант
model UserPreference {
  userId           String  @id
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedTenantId String?
  locale           String?
  timezone         String?
  updatedAt        DateTime @updatedAt
}

// Identity-провайдеры (future-ready: OAuth, SMS)
model AuthIdentity {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        AuthProvider
  providerSubject String?
  isPrimary       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerSubject])
  @@index([userId])
}

// -------------------------------------------------------------------
// 2. КОМПАНИЯ (TENANT) И КОМАНДА
// -------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessState AccessState @default(EARLY_ACCESS)

  taxSystem            TaxSystem @default(USN_6)
  vatThresholdExceeded Boolean   @default(false)

  memberships         Membership[]
  marketplaceAccounts MarketplaceAccount[]
  products            Product[]
  orders              MarketplaceOrder[]
  auditLogs           AuditLog[]
  reports             MarketplaceReport[]
}

model Membership {
  id   String @id @default(uuid())
  role Role   @default(MANAGER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenantId])
}

// -------------------------------------------------------------------
// 3. ИНТЕГРАЦИИ
// -------------------------------------------------------------------

model MarketplaceAccount {
  id          String          @id @default(uuid())
  name        String
  marketplace MarketplaceType

  clientId    String?
  apiKey      String?
  statApiKey  String?
  warehouseId String?

  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------------
// 4. БИЗНЕС СУЩНОСТИ (ТОВАРЫ, ЗАКАЗЫ)
// -------------------------------------------------------------------

model Product {
  id       String  @id @default(uuid())
  sku      String
  name     String
  photo    String?
  total    Int     @default(0)
  reserved Int     @default(0)

  purchasePrice  Float? @default(0)
  minPrice       Float?
  vatRate        Int    @default(0)
  commissionRate Float?
  logisticsCost  Float?

  category String?
  width    Float?
  height   Float?
  length   Float?
  weight   Float?

  rating    Float?  @default(0)
  wbBarcode String?

  ozonFbs Int @default(0)
  ozonFbo Int @default(0)
  wbFbs   Int @default(0)
  wbFbo   Int @default(0)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@unique([tenantId, wbBarcode])
}

model MarketplaceOrder {
  id                 String          @id @default(uuid())
  marketplaceOrderId String
  marketplace        MarketplaceType
  productSku         String?
  productNames       String?
  quantity           Int

  status               String?
  totalAmount          Float?
  sellerPrice          Float?
  currency             String?   @default("RUB")
  shipmentDate         DateTime?
  marketplaceCreatedAt DateTime?
  deliveryMethod       String?

  region String?
  city   String?

  createdAt   DateTime @default(now())
  processedAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, marketplaceOrderId])
}

model MarketplaceReport {
  id          String          @id @default(uuid())
  reportId    String
  marketplace MarketplaceType
  periodStart DateTime
  periodEnd   DateTime

  salesAmount      Float @default(0)
  returnsAmount    Float @default(0)
  commissionAmount Float @default(0)
  logisticsAmount  Float @default(0)
  storageAmount    Float @default(0)
  otherDeductions  Float @default(0)
  netToPay         Float @default(0)

  rawJson String?

  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reportId])
}

model AuditLog {
  id         String     @id @default(uuid())
  actionType ActionType
  createdAt  DateTime   @default(now())

  productId  String?
  productSku String?

  beforeTotal Int?
  afterTotal  Int?
  delta       Int?

  beforeName String?
  afterName  String?

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id])
  note        String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------
// ENUMS
// -------------------------------------------------------------------

enum TaxSystem {
  USN_6
  USN_15
  OSNO
  NPD
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum AccessState {
  EARLY_ACCESS
  TRIAL_ACTIVE
  TRIAL_EXPIRED
  ACTIVE_PAID
  GRACE_PERIOD
  SUSPENDED
  CLOSED
}

enum TenantStatus {
  ACTIVE
  CLOSED
}

enum TenantActorType {
  SYSTEM
  BILLING
  SUPPORT
  USER
}

enum TenantClosureJobStatus {
  PENDING
  PROCESSING
  ARCHIVED
  DELETED
  FAILED
}

enum MarketplaceType {
  WB
  OZON
}

enum ActionType {
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STOCK_ADJUSTED
  ORDER_DEDUCTED
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REVOKED
  LEFT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// Auth enums
enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
  DELETED
}

enum AuthSessionStatus {
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED
  COMPROMISED
}

enum ChallengeStatus {
  PENDING
  USED
  EXPIRED
  CANCELLED
}

enum AuthProvider {
  LOCAL
  TELEGRAM
  GOOGLE
  YANDEX
  SMS
}

enum OnboardingScope {
  USER_BOOTSTRAP    // до создания tenant (шаг: create_company)
  TENANT_ACTIVATION // после создания tenant (интеграции, каталог, команда)
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum OnboardingStepStatus {
  PENDING
  VIEWED
  DONE
  SKIPPED
}

// -------------------------------------------------------------------
// 1. ПОЛЬЗОВАТЕЛИ И AUTH
// -------------------------------------------------------------------

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // Telegram — временно остаётся здесь, будет вынесено в AuthIdentity
  telegramId String? @unique

  // Инкрементируется при любом изменении состава memberships;
  // JWT использует его для валидации кешированного activeTenantId.
  membershipVersion Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Membership[]
  auditLogs          AuditLog[]
  authSessions       AuthSession[]
  emailVerifications EmailVerificationChallenge[]
  passwordResets     PasswordResetChallenge[]
  preferences        UserPreference?
  authIdentities     AuthIdentity[]
  ownedTenants       Tenant[]                     @relation("TenantPrimaryOwner")
  sentInvitations    Invitation[]                 @relation("InvitationSentBy")
  acceptedInvitations Invitation[]                @relation("InvitationAcceptedBy")
  teamEvents         TeamEvent[]                  @relation("TeamEventActor")
  onboardingStates   OnboardingState[]
}

// Серверные сессии с refresh token rotation и reuse detection
model AuthSession {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String            @unique
  status           AuthSessionStatus @default(ACTIVE)
  ip               String?
  userAgent        String?
  lastSeenAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, status])
}

// Одноразовые токены подтверждения email (хранится hash, не plaintext)
model EmailVerificationChallenge {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailSnapshot String
  tokenHash     String          @unique
  status        ChallengeStatus @default(PENDING)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
}

// Одноразовые токены сброса пароля (хранится hash, не plaintext)
model PasswordResetChallenge {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String          @unique
  status    ChallengeStatus @default(PENDING)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

// Пользовательские настройки — последний активный тенант
model UserPreference {
  userId           String  @id
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedTenantId String?
  locale           String?
  timezone         String?
  updatedAt        DateTime @updatedAt
}

// Неудачные попытки входа — для soft-lock по паре (email + IP)
model LoginAttempt {
  id              String   @id @default(uuid())
  normalizedEmail String
  ip              String
  createdAt       DateTime @default(now())

  @@index([normalizedEmail, ip, createdAt])
}

// Identity-провайдеры (future-ready: OAuth, SMS)
model AuthIdentity {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        AuthProvider
  providerSubject String?
  isPrimary       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerSubject])
  @@index([userId])
}

// -------------------------------------------------------------------
// 2. КОМПАНИЯ (TENANT) И КОМАНДА
// -------------------------------------------------------------------

model Tenant {
  id          String       @id @default(uuid())
  name        String
  inn         String?
  status      TenantStatus @default(ACTIVE)
  accessState AccessState  @default(EARLY_ACCESS)

  primaryOwnerUserId String?
  primaryOwner       User?   @relation("TenantPrimaryOwner", fields: [primaryOwnerUserId], references: [id], onDelete: SetNull)

  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  settings          TenantSettings?
  accessStateEvents TenantAccessStateEvent[]
  closureJob        TenantClosureJob?

  memberships         Membership[]
  marketplaceAccounts MarketplaceAccount[]
  products            Product[]
  orders              MarketplaceOrder[]
  auditLogs           AuditLog[]
  reports             MarketplaceReport[]
  invitations         Invitation[]
  teamEvents          TeamEvent[]
  onboardingStates    OnboardingState[]
}

// Настройки компании, вынесены из Tenant для чистоты модели
model TenantSettings {
  tenantId             String    @id
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  taxSystem            TaxSystem @default(USN_6)
  vatThresholdExceeded Boolean   @default(false)
  country              String?
  currency             String?
  timezone             String?
  legalName            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// История переходов AccessState — audit trail каждого изменения
model TenantAccessStateEvent {
  id            String          @id @default(uuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromState     AccessState?
  toState       AccessState
  reasonCode    String
  reasonDetails Json?
  actorType     TenantActorType
  actorId       String?
  createdAt     DateTime        @default(now())

  @@index([tenantId, createdAt])
}

// Задача на retention/archival после закрытия tenant
model TenantClosureJob {
  id            String                 @id @default(uuid())
  tenantId      String                 @unique
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status        TenantClosureJobStatus @default(PENDING)
  scheduledFor  DateTime
  processedAt   DateTime?
  failureReason String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model Membership {
  id     String           @id @default(uuid())
  role   Role             @default(MANAGER)
  status MembershipStatus @default(ACTIVE)

  joinedAt  DateTime?
  revokedAt DateTime?
  leftAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([tenantId, status])
}

model Invitation {
  id    String           @id @default(uuid())
  email String
  role  Role
  status InvitationStatus @default(PENDING)

  tokenHash String @unique

  expiresAt    DateTime
  acceptedAt   DateTime?
  cancelledAt  DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User   @relation("InvitationSentBy", fields: [invitedByUserId], references: [id])

  acceptedByUserId String?
  acceptedBy       User?   @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tokenHash])
}

model TeamEvent {
  id          String   @id @default(uuid())
  eventType   String
  payload     Json?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  actorUserId String?
  actor       User?   @relation("TeamEventActor", fields: [actorUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// -------------------------------------------------------------------
// 3. ИНТЕГРАЦИИ
// -------------------------------------------------------------------

model MarketplaceAccount {
  id          String          @id @default(uuid())
  name        String
  marketplace MarketplaceType

  clientId    String?
  apiKey      String?
  statApiKey  String?
  warehouseId String?

  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------------
// 4. БИЗНЕС СУЩНОСТИ (ТОВАРЫ, ЗАКАЗЫ)
// -------------------------------------------------------------------

model Product {
  id       String  @id @default(uuid())
  sku      String
  name     String
  photo    String?
  total    Int     @default(0)
  reserved Int     @default(0)

  purchasePrice  Float? @default(0)
  minPrice       Float?
  vatRate        Int    @default(0)
  commissionRate Float?
  logisticsCost  Float?

  category String?
  width    Float?
  height   Float?
  length   Float?
  weight   Float?

  rating    Float?  @default(0)
  wbBarcode String?

  ozonFbs Int @default(0)
  ozonFbo Int @default(0)
  wbFbs   Int @default(0)
  wbFbo   Int @default(0)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@unique([tenantId, wbBarcode])
}

model MarketplaceOrder {
  id                 String          @id @default(uuid())
  marketplaceOrderId String
  marketplace        MarketplaceType
  productSku         String?
  productNames       String?
  quantity           Int

  status               String?
  totalAmount          Float?
  sellerPrice          Float?
  currency             String?   @default("RUB")
  shipmentDate         DateTime?
  marketplaceCreatedAt DateTime?
  deliveryMethod       String?

  region String?
  city   String?

  createdAt   DateTime @default(now())
  processedAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, marketplaceOrderId])
}

model MarketplaceReport {
  id          String          @id @default(uuid())
  reportId    String
  marketplace MarketplaceType
  periodStart DateTime
  periodEnd   DateTime

  salesAmount      Float @default(0)
  returnsAmount    Float @default(0)
  commissionAmount Float @default(0)
  logisticsAmount  Float @default(0)
  storageAmount    Float @default(0)
  otherDeductions  Float @default(0)
  netToPay         Float @default(0)

  rawJson String?

  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reportId])
}

model AuditLog {
  id         String     @id @default(uuid())
  actionType ActionType
  createdAt  DateTime   @default(now())

  productId  String?
  productSku String?

  beforeTotal Int?
  afterTotal  Int?
  delta       Int?

  beforeName String?
  afterName  String?

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id])
  note        String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------------
// 5. ОНБОРДИНГ
// -------------------------------------------------------------------

// Состояние онбординга — user_bootstrap (до создания tenant) или tenant_activation (после)
model OnboardingState {
  id             String           @id @default(uuid())
  scope          OnboardingScope
  status         OnboardingStatus @default(IN_PROGRESS)
  catalogVersion String           @default("v1")
  lastStepKey    String?
  completedAt    DateTime?
  closedAt       DateTime?

  // USER_BOOTSTRAP scope: привязан к пользователю, tenantId = null
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // TENANT_ACTIVATION scope: привязан к компании, userId = null
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps OnboardingStepProgress[]

  // Один USER_BOOTSTRAP на пользователя; PostgreSQL допускает несколько (NULL, ...) в уникальном индексе
  @@unique([userId, scope])
  // Один TENANT_ACTIVATION на tenant
  @@unique([tenantId, scope])
  @@index([userId])
  @@index([tenantId])
}

// Прогресс по каждому шагу онбординга (один ряд на stepKey)
model OnboardingStepProgress {
  id                String               @id @default(uuid())
  onboardingStateId String
  onboardingState   OnboardingState      @relation(fields: [onboardingStateId], references: [id], onDelete: Cascade)
  stepKey           String
  status            OnboardingStepStatus @default(PENDING)
  viewedAt          DateTime?
  completedAt       DateTime?
  skippedAt         DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([onboardingStateId, stepKey])
  @@index([onboardingStateId])
}

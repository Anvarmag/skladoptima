generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  products            Product[]
  marketplaceOrders   MarketplaceOrder[]
  auditLogs           AuditLog[]
  marketplaceSettings MarketplaceSettings?
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  telegramId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Product {
  id        String    @id @default(uuid())
  sku       String
  name      String
  photo     String?   // URL or path to uploaded file
  total     Int       @default(0)
  reserved  Int       @default(0)

  // Marketplace barcodes for matching
  wbBarcode String?

  // Marketplace cached stock
  ozonFbs   Int       @default(0)
  ozonFbo   Int       @default(0)
  wbFbs     Int       @default(0)
  wbFbo     Int       @default(0)

  deletedAt DateTime? // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, sku]) // SKU unique per store
  @@unique([storeId, wbBarcode]) // Barcode unique per store
}

enum ActionType {
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STOCK_ADJUSTED
  ORDER_DEDUCTED
}

// Track processed orders to prevent double-deduction
model MarketplaceOrder {
  id                 String   @id @default(uuid())
  marketplaceOrderId String   // WB Order ID or Ozon Posting Number
  marketplace        String   // "WB" or "OZON"
  productSku         String?
  productNames       String?  // Названия товаров
  quantity           Int
  
  status             String?  // Статус из МП
  totalAmount        Float?   // Сумма заказа
  currency           String?  @default("RUB")
  shipmentDate       DateTime? // Дата отгрузки
  marketplaceCreatedAt DateTime? // Дата создания в МП
  deliveryMethod     String?  // Способ доставки
  
  createdAt          DateTime @default(now())
  processedAt        DateTime @default(now())

  storeId            String
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, marketplaceOrderId]) // Order ID unique per store
}

model AuditLog {
  id          String     @id @default(uuid())
  actionType  ActionType
  createdAt   DateTime   @default(now())
  
  productId   String?
  productSku  String?
  
  beforeTotal Int?
  afterTotal  Int?
  delta       Int?
  
  beforeName  String?
  afterName   String?
  
  actorEmail  String
  note        String?

  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model MarketplaceSettings {
  id              String   @id @default(uuid())
  ozonClientId    String?
  ozonApiKey      String?
  ozonWarehouseId String?
  wbApiKey        String?
  wbStatApiKey    String?
  wbWarehouseId   String?

  updatedAt DateTime @updatedAt

  storeId         String   @unique
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

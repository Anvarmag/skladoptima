generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaxSystem {
  USN_6
  USN_15
  OSNO
  NPD
}

model Store {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Taxation settings
  taxSystem           TaxSystem @default(USN_6)
  vatThresholdExceeded Boolean   @default(false) // For USN with VAT (2025+ rules)

  users               User[]
  products            Product[]
  marketplaceOrders   MarketplaceOrder[]
  auditLogs           AuditLog[]
  marketplaceSettings MarketplaceSettings?
  marketplaceReports  MarketplaceReport[]
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  telegramId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Product {
  id        String    @id @default(uuid())
  sku       String
  name      String
  photo     String?   // URL or path to uploaded file
  total     Int       @default(0)
  reserved  Int       @default(0)

  // Financial fields
  purchasePrice Float?     @default(0) // Себестоимость закупочная
  minPrice      Float?     // Минимально допустимая цена для рекомендаций
  vatRate       Int        @default(0) // 0, 10, 20
  commissionRate Float?     // Комиссия маркетплейса (в %)
  logisticsCost  Float?     // Стоимость логистики (на ед.)
  
  // Dimensions and Category for automated fee calculation
  category      String?    // Категория товара на маркетплейсе
  width         Float?     // Ширина упаковки (см)
  height        Float?     // Высота упаковки (см)
  length        Float?     // Длина упаковки (см)
  weight        Float?     // Вес с упаковкой (кг)

  // Analytics fields
  rating        Float?     @default(0) // Рейтинг из маркетплейса

  // Marketplace barcodes for matching
  wbBarcode String?

  // Marketplace cached stock
  ozonFbs   Int       @default(0)
  ozonFbo   Int       @default(0)
  wbFbs     Int       @default(0)
  wbFbo     Int       @default(0)

  deletedAt DateTime? // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, sku]) // SKU unique per store
  @@unique([storeId, wbBarcode]) // Barcode unique per store
}

enum ActionType {
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STOCK_ADJUSTED
  ORDER_DEDUCTED
}

// Track processed orders to prevent double-deduction
model MarketplaceOrder {
  id                 String   @id @default(uuid())
  marketplaceOrderId String   // WB Order ID or Ozon Posting Number
  marketplace        String   // "WB" or "OZON"
  productSku         String?
  productNames       String?  // Названия товаров
  quantity           Int
  
  status             String?  // Статус из МП
  totalAmount        Float?   // Сумма заказа (реализация)
  sellerPrice        Float?   // Цена продавца в ЛК (для расчета налогов)
  currency           String?  @default("RUB")
  shipmentDate       DateTime? // Дата отгрузки
  marketplaceCreatedAt DateTime? // Дата создания в МП
  deliveryMethod     String?  // Способ доставки
  
  // Locations for analytics
  region             String?  // Регион/Область
  city               String?  // Город

  createdAt          DateTime @default(now())
  processedAt        DateTime @default(now())

  storeId            String
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, marketplaceOrderId]) // Order ID unique per store
}

// Advanced financial reports from MP (Weekly realization reports, etc.)
model MarketplaceReport {
  id               String   @id @default(uuid())
  reportId         String
  marketplace      String   // "WB" or "OZON"
  periodStart      DateTime
  periodEnd        DateTime
  
  salesAmount      Float    @default(0)
  returnsAmount    Float    @default(0)
  commissionAmount Float    @default(0)
  logisticsAmount  Float    @default(0)
  storageAmount    Float    @default(0)
  otherDeductions  Float    @default(0)
  netToPay         Float    @default(0)
  
  rawJson          String?  // Store original data for debugging

  createdAt        DateTime @default(now())
  storeId          String
  store            Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, reportId])
}

model AuditLog {
  id          String     @id @default(uuid())
  actionType  ActionType
  createdAt   DateTime   @default(now())
  
  productId   String?
  productSku  String?
  
  beforeTotal Int?
  afterTotal  Int?
  delta       Int?
  
  beforeName  String?
  afterName   String?
  
  actorEmail  String
  note        String?

  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model MarketplaceSettings {
  id              String   @id @default(uuid())
  ozonClientId    String?
  ozonApiKey      String?
  ozonWarehouseId String?
  wbApiKey        String?
  wbStatApiKey    String?
  wbWarehouseId   String?

  // Sync Diagnostics
  lastWbSyncAt    DateTime?
  lastWbSyncError String?
  lastOzonSyncAt    DateTime?
  lastOzonSyncError String?

  updatedAt DateTime @updatedAt

  storeId         String   @unique
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

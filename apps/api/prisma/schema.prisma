  requestId     String?
  correlationId String?
  before        Json?
  after         Json?
  changedFields Json?
  metadata      Json?

  visibilityScope AuditVisibilityScope @default(tenant)
  redactionLevel  AuditRedactionLevel  @default(none)

  // Legacy fields — kept for backward compat, will be removed after writer migration (TASK_AUDIT_2)
  actionType  ActionType?
  productId   String?
  productSku  String?
  beforeTotal Int?
  afterTotal  Int?
  delta       Int?
  beforeName  String?
  afterName   String?
  actorUserId String?
  actorUser   User?       @relation(fields: [actorUserId], references: [id])
  note        String?

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId, createdAt(sort: Desc)])
  @@index([requestId])
}

model SecurityEvent {
  id        String            @id @default(uuid())
  tenantId  String?
  tenant    Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType SecurityEventType
  ip        String?
  userAgent String?
  requestId String?
  metadata  Json?
  createdAt DateTime          @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType])
  @@index([requestId])
}

// -------------------------------------------------------------------
// 5. ОНБОРДИНГ
// -------------------------------------------------------------------

// Состояние онбординга — user_bootstrap (до создания tenant) или tenant_activation (после)
model OnboardingState {
  id             String           @id @default(uuid())
  scope          OnboardingScope
  status         OnboardingStatus @default(IN_PROGRESS)
  catalogVersion String           @default("v1")
  lastStepKey    String?
  completedAt    DateTime?
  closedAt       DateTime?

  // USER_BOOTSTRAP scope: привязан к пользователю, tenantId = null
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // TENANT_ACTIVATION scope: привязан к компании, userId = null
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps OnboardingStepProgress[]

  // Один USER_BOOTSTRAP на пользователя; PostgreSQL допускает несколько (NULL, ...) в уникальном индексе
  @@unique([userId, scope])
  // Один TENANT_ACTIVATION на tenant
  @@unique([tenantId, scope])
  @@index([userId])
  @@index([tenantId])
}

// -------------------------------------------------------------------
// 6. INVENTORY — Балансы, движения, idempotency, настройки
// -------------------------------------------------------------------

// Агрегированный баланс по (tenant, product, warehouse).
// available — STORED GENERATED column (onHand - reserved); сервисный код
// никогда не должен записывать его явно — Prisma пропускает поле с
// @default(dbgenerated()), а БД сама вычисляет значение.
model StockBalance {
  id              String                   @id @default(uuid())
  tenantId        String
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId       String
  product         Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId     String
  fulfillmentMode InventoryFulfillmentMode @default(FBS)
  isExternal      Boolean                  @default(false)
  onHand          Int                      @default(0)
  reserved        Int                      @default(0)
  available       Int                      @default(dbgenerated())
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId, productId])
  @@index([tenantId, fulfillmentMode])
}

// Лог любого изменения остатка/резерва. Источник истины для расследований.
model StockMovement {
  id             String              @id @default(uuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId      String
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId    String?
  movementType   StockMovementType
  delta          Int
  onHandBefore   Int?
  onHandAfter    Int?
  reservedBefore Int?
  reservedAfter  Int?
  reasonCode     String?             @db.VarChar(64)
  comment        String?
  source         StockMovementSource
  sourceEventId  String?             @db.VarChar(128)
  idempotencyKey String?             @db.VarChar(128)
  actorUserId    String?
  actorUser      User?               @relation("StockMovementActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())

  @@index([tenantId, productId, createdAt])
  @@index([tenantId, sourceEventId])
  @@index([tenantId, movementType, createdAt])
}

// Idempotency-замок для применения внешних/business-событий ровно один раз.
// UNIQUE(tenantId, effectType, sourceEventId) гарантирует, что один и тот же
// reserve/release/deduct не применится дважды.
model InventoryEffectLock {
  id            String                @id @default(uuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  effectType    InventoryEffectType
  sourceEventId String                @db.VarChar(128)
  status        InventoryEffectStatus @default(PROCESSING)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([tenantId, effectType, sourceEventId])
  @@index([tenantId, status])
}

// Настройки инвентаря на уровне tenant. Пока — только low-stock порог.
model InventorySettings {
  tenantId          String   @id
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lowStockThreshold Int      @default(5)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// -------------------------------------------------------------------
// 7. WAREHOUSES — справочник внешних складов (TASK_WAREHOUSES_1)
// -------------------------------------------------------------------

/// Справочник внешних складов tenant. Источник истины — marketplace API
/// (sync upsert по `(tenantId, marketplaceAccountId, externalWarehouseId)`).
/// `aliasName` и `labels` — единственные поля, которые редактирует tenant;
/// остальные атрибуты read-only по политике §13/§20 system-analytics.
/// Lifecycle ACTIVE → INACTIVE (склад исчез из API после safe-window) →
/// ARCHIVED (долго не возвращается). Удаление запрещено — историческая
/// связь с inventory должна сохраняться.
model Warehouse {
  id                   String             @id @default(uuid())
  tenantId             String
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)

  externalWarehouseId String  @db.VarChar(128)
  name                String  @db.VarChar(255)
  city                String? @db.VarChar(128)

  warehouseType     WarehouseType
  sourceMarketplace WarehouseSourceMarketplace

  // tenant-локальные поля (могут редактироваться через PATCH /metadata).
  aliasName String?  @db.VarChar(255)
  labels    String[] @default([])

  status             WarehouseStatus @default(ACTIVE)
  deactivationReason String?         @db.VarChar(64)

  firstSeenAt   DateTime  @default(now())
  lastSyncedAt  DateTime?
  inactiveSince DateTime?

  metadataUpdatedAt     DateTime?
  metadataUpdatedBy     String?
  metadataUpdatedByUser User?     @relation("WarehouseMetadataUpdatedBy", fields: [metadataUpdatedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  orderItems OrderItem[]

  @@unique([tenantId, marketplaceAccountId, externalWarehouseId])
  @@index([tenantId, status])
  @@index([tenantId, sourceMarketplace, warehouseType])
  @@index([marketplaceAccountId, status])
}

// Прогресс по каждому шагу онбординга (один ряд на stepKey)
model OnboardingStepProgress {
  id                String               @id @default(uuid())
  onboardingStateId String
  onboardingState   OnboardingState      @relation(fields: [onboardingStateId], references: [id], onDelete: Cascade)
  stepKey           String
  status            OnboardingStepStatus @default(PENDING)
  viewedAt          DateTime?
  completedAt       DateTime?
  skippedAt         DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([onboardingStateId, stepKey])
  @@index([onboardingStateId])
}


// -------------------------------------------------------------------
// Finance domain (TASK_FINANCE_1) — см. 11-finance system-analytics
// §8/§13/§14.
//
// Зачем отдельные таблицы рядом с legacy полями `Product.purchasePrice`
// и др.: §13 правило источников истины запрещает finance модулю опираться
// на разрозненные поля каталога без явного profile. Legacy `Product.*Cost`
// сохраняется (его использует существующий `finance.service.ts` MVP),
// переключение читателей на `ProductFinanceProfile` — TASK_FINANCE_2/3.
// -------------------------------------------------------------------

/// Профиль себестоимости товара. Manual input в MVP разрешён ТОЛЬКО для
/// `baseCost`, `packagingCost`, `additionalCost` (§10 + §13: ручной ввод
/// периодных расходов и подмена marketplace fees запрещены).
/// `isCostManual=true` фиксирует, что значения введены вручную, а не
/// получены автоматическим pipeline'ом — нужно для warning'ов когда
/// автомат хочет перетереть значение, но manual явно выставлен.
model ProductFinanceProfile {
  id              String  @id @default(uuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId       String  @unique
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // NUMERIC(12,2) — точное представление денег без float-дрифта.
  baseCost        Decimal? @db.Decimal(12, 2)
  packagingCost   Decimal? @db.Decimal(12, 2)
  additionalCost  Decimal? @db.Decimal(12, 2)

  costCurrency    String  @default("RUB") @db.VarChar(3)
  isCostManual    Boolean @default(true)

  updatedBy       String?
  updatedByUser   User?    @relation("FinanceProfileUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Один профиль на (tenant, product) — UNIQUE на productId уже даёт
  // это, но явный композитный индекс ускоряет фильтр по tenantId.
  @@index([tenantId, productId])
}

/// Снимок периода юнит-экономики (§14 формулы MVP). Содержит
/// агрегированный `payload JSONB` с per-SKU цифрами + сводными KPI.
/// `formulaVersion` гарантирует воспроизводимость: если мы поменяли
/// формулу, старые snapshots сохраняют свою версию и UI рендерит
/// исторические периоды стабильно (§20 риск non-reproducible reports).
///
/// `snapshotStatus=INCOMPLETE` отделён от `READY` и `FAILED` сознательно:
/// расчёт прошёл, но критичные source отсутствуют — UI показывает данные
/// с warning, а не молчаливыми нулями (§14 правило неполного расчёта).
///
/// Идемпотентность по `(tenantId, periodFrom, periodTo, formulaVersion)`
/// — повторный rebuild того же периода с той же формулой не создаёт
/// дубль; новая формула версионирует snapshot отдельно.
model FinanceSnapshot {
  id              String                    @id @default(uuid())
  tenantId        String
  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  periodFrom      DateTime                  @db.Date
  periodTo        DateTime                  @db.Date
  periodType      FinanceSnapshotPeriodType

  formulaVersion  String                    @db.VarChar(32)
  snapshotStatus  FinanceSnapshotStatus     @default(READY)

  payload         Json
  // Source diagnostics: когда последний raw report пришёл, какой sync_run
  // использовался, считается ли источник `stale` per §14. Структура:
  // { orders: { lastEventAt, isStale }, fees: {...}, ads: {...} }.
  sourceFreshness Json?

  generatedAt     DateTime                  @default(now())
  generatedBy     String?
  generatedByUser User?                     @relation("FinanceSnapshotGeneratedBy", fields: [generatedBy], references: [id], onDelete: SetNull)

  warnings        FinanceDataWarning[]

  // Идемпотентность rebuild — UNIQUE по (tenant, period, formula).
  @@unique([tenantId, periodFrom, periodTo, formulaVersion])
  // UI: список последних snapshot'ов tenant'а.
  @@index([tenantId, periodTo, generatedAt])
  @@index([tenantId, snapshotStatus, generatedAt])
}

/// Предупреждение о неполных или устаревших данных (§13 правило
/// источников истины + §14 правило неполного расчёта).
///
/// Привязка к `productId` опциональна: warning может быть как per-SKU
/// (`MISSING_COST`), так и tenant-wide (`STALE_FINANCIAL_SOURCE` без
/// конкретного товара). Привязка к `snapshotId` тоже опциональна:
/// realtime-расчёт без snapshot ещё может вернуть warning'и для UI.
///
/// `isActive=false` + `resolvedAt` фиксируется warning resolution job'ом
/// (§15) после появления недостающих данных — мы НЕ удаляем warning
/// физически, чтобы аналитика могла видеть историю incomplete-периодов.
model FinanceDataWarning {
  id           String              @id @default(uuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId    String?
  product      Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)

  snapshotId   String?
  snapshot     FinanceSnapshot?    @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  warningType  FinanceWarningType
  isActive     Boolean             @default(true)

  // Дополнительный контекст: missingComponents, lastReliableAt и т.п.
  details      Json?

  createdAt    DateTime            @default(now())
  resolvedAt   DateTime?

  // §19 dashboards: completeness board / stale-source board.
  @@index([tenantId, isActive, warningType])
  @@index([tenantId, productId])
  @@index([snapshotId])
}


// -------------------------------------------------------------------
// Analytics domain (TASK_ANALYTICS_1) — см. 12-analytics system-analytics
// §8/§13/§18.
//
// Зачем отдельный data-layer рядом с уже существующим `analytics.service.ts`:
// §13 явно требует, чтобы dashboard и ABC не считались on-the-fly из OLTP.
// Текущий MVP агрегирует `MarketplaceOrder` циклом по дням — это ляжет на
// первой большой выборке. Эти таблицы — read-model витрина, которая
// заполняется nightly job'ом (TASK_ANALYTICS_2/3) и читается API без
// тяжёлых join'ов.
//
// Legacy `analytics.service.ts` сохраняется (его дёргает frontend) —
// переключение читателей на новые таблицы происходит в TASK_ANALYTICS_4
// одновременно с появлением fast read API.
// -------------------------------------------------------------------

/// Дневной материализованный слой (§8 + §13). Одна строка на (tenant, date)
/// — ключевая витрина для revenue dynamics, dashboard KPI и базы под ABC.
///
/// Все денежные поля — `Decimal(14,2)` для точности агрегатов; `by_marketplace`
/// — JSONB вида `{ "WB": { "revenueNet": 12345.67, "ordersCount": 12,
/// "unitsSold": 18 }, "OZON": {...} }` — позволяет дашборду показывать
/// per-channel разбивку без отдельной таблицы на каждый маркетплейс.
///
/// `sourceFreshness` — диагностика, по которой UI решает рисовать `fresh`
/// / `stale` / `incomplete` бейдж (§7 frontend поведение). Структура:
/// `{ orders: { lastEventAt, isStale }, finance: {...}, integrations: {...} }`.
///
/// `formulaVersion` фиксирует версию набора формул KPI (`avg_check =
/// revenue_net / orders_count` и т.п.) — если правила меняются, старые
/// строки пересчитываются rebuild'ом, а не молчаливо переинтерпретируются
/// (§20 риск non-explainable аналитики).
model AnalyticsMaterializedDaily {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  date           DateTime @db.Date

  revenueGross   Decimal  @default(0) @db.Decimal(14, 2)
  revenueNet     Decimal  @default(0) @db.Decimal(14, 2)
  ordersCount    Int      @default(0)
  unitsSold      Int      @default(0)
  returnsCount   Int      @default(0)
  avgCheck       Decimal  @default(0) @db.Decimal(12, 2)

  byMarketplace  Json
  sourceFreshness Json?

  formulaVersion String                  @db.VarChar(32)
  snapshotStatus AnalyticsSnapshotStatus @default(READY)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // §15 идемпотентность daily aggregation: повторный запуск job'а на тот же
  // (tenant, date) — upsert, а не дубль.
  @@unique([tenantId, date])
  // Revenue dynamics / dashboard читают окно `[from, to]` per tenant,
  // отсортированное по date desc — самый горячий индекс модуля.
  @@index([tenantId, date])
  // §19 stale-vs-incomplete board.
  @@index([tenantId, snapshotStatus, date])
}

/// ABC-снапшот за период (§14 правила ABC). Хранится payload'ом, потому
/// что внутри — массив SKU с накопительной долей и групповой меткой;
/// отдельная таблица per-SKU тут оверкилл (snapshot читается целиком
/// при открытии экрана и редко поштучно).
///
/// Идемпотентность по `(tenantId, periodFrom, periodTo, metric,
/// formulaVersion)` — пересчёт того же периода с той же метрикой и
/// версией формулы переписывает payload, а смена metric / formulaVersion
/// создаёт отдельный snapshot, чтобы не терять историю интерпретации.
///
/// `snapshotStatus=INCOMPLETE` — частично пересчитан (например, не все
/// маркетплейсы отдали отчёты по периоду). `STALE` — daily layer под ABC
/// не обновлялся допустимое окно. UI показывает обе ситуации с бейджем,
/// но не скрывает данные (§14 + §20).
model AnalyticsAbcSnapshot {
  id             String                  @id @default(uuid())
  tenantId       String
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  periodFrom     DateTime                @db.Date
  periodTo       DateTime                @db.Date
  metric         AnalyticsAbcMetric

  formulaVersion String                  @db.VarChar(32)
  snapshotStatus AnalyticsSnapshotStatus @default(READY)

  payload        Json
  sourceFreshness Json?

  generatedAt    DateTime                @default(now())

  // §15 идемпотентность rebuild + историзация по (period, metric, formula).
  @@unique([tenantId, periodFrom, periodTo, metric, formulaVersion])
  // UI: список последних снапшотов tenant'а, сортировка по periodTo.
  @@index([tenantId, periodTo, generatedAt])
  // §19 health board.
  @@index([tenantId, snapshotStatus, generatedAt])
}

/// Explainable rule-based рекомендация (§9 шаг 5 + §20 риск
/// «recommendation должна быть объяснимой»). Каждая запись — конкретный
/// сигнал: `ruleKey` идентифицирует правило-эвристику, `reasonCode` —
/// машинно-читаемое объяснение, `message` — человекочитаемая копия для UI.
///
/// `productId` опционален: рекомендация может быть привязана к SKU
/// (`LOW_STOCK_HIGH_DEMAND`) или быть tenant-wide (`STALE_ANALYTICS_SOURCE`).
///
/// `payload` — дополнительный контекст для drill-down: какие именно
/// числа спровоцировали правило (current stock, daily velocity и т.п.),
/// чтобы UI мог раскрыть «почему именно это правило сработало».
///
/// `status=ACTIVE` — рекомендация актуальна. `DISMISSED` / `APPLIED`
/// зарезервированы под будущий workflow (§15 MVP правило: пользовательский
/// dismiss/applied не входит в первую версию). В MVP rule engine выставляет
/// `DISMISSED` сам, когда сигнал устаревает (например, остаток пополнен).
model AnalyticsRecommendation {
  id             String                          @id @default(uuid())
  tenantId       String
  tenant         Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId      String?
  product        Product?                        @relation(fields: [productId], references: [id], onDelete: SetNull)

  ruleKey        String                          @db.VarChar(64)
  reasonCode     String                          @db.VarChar(64)
  priority       AnalyticsRecommendationPriority
  status         AnalyticsRecommendationStatus   @default(ACTIVE)

  message        String
  payload        Json?

  formulaVersion String                          @db.VarChar(32)

  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt
  resolvedAt     DateTime?

  // §15 идемпотентность recommendation refresh: один активный сигнал
  // на (tenant, product, ruleKey). Повторный запуск engine'а на том же
  // продукте с тем же правилом — upsert в актуальное состояние.
  // NB: productId NULL участвует в UNIQUE как самостоятельное значение
  // (Postgres NULLS DISTINCT — поведение по умолчанию), что нам и нужно
  // для tenant-wide правил без привязки к SKU.
  @@unique([tenantId, productId, ruleKey])
  // UI: топ активных рекомендаций по приоритету.
  @@index([tenantId, status, priority])
  // Drill-down по конкретному SKU.
  @@index([tenantId, productId])
}


// -------------------------------------------------------------------
// Referrals domain (TASK_REFERRALS_1) — см. 14-referrals system-analytics
// §8/§13.
// -------------------------------------------------------------------

/// Реферальная ссылка/код владельца. Один владелец может иметь несколько
/// ссылок (под разные кампании), но §6 MVP хранит **одну активную ссылку
/// на (ownerUserId, tenantId)** — UNIQUE даёт идемпотентность getOrCreate.
///
/// `code` — короткий, чувствительный к регистру публичный токен (8 символов
/// base32). UNIQUE глобально, чтобы не было коллизий между tenant'ами.
model ReferralLink {
  id          String   @id @default(uuid())
  ownerUserId String
  ownerUser   User     @relation("ReferralLinkOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String   @unique @db.VarChar(32)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attributions ReferralAttribution[]

  // §6: одна активная ссылка на (owner, tenant). Для MVP одна — точка
  // получения через `GET /referrals/link` (TASK_REFERRALS_1).
  @@unique([ownerUserId, tenantId])
  @@index([ownerUserId])
}

/// Атрибуция приглашения. Создаётся в два этапа (§13):
///   1. Регистрация — `referredUserId` зафиксирован, `referredTenantId=null`,
///      статус `ATTRIBUTED`. Сохраняется attribution context (utm_*,
///      sourceIp, userAgent) — без потери источника после редиректов.
///   2. Tenant creation — `referredTenantId` заполняется. UNIQUE на
///      `referredTenantId` обеспечивает attribution **lock**: tenant
///      нельзя silently переподписать на другой referral_code.
///
/// Self-referral (owner === referred user или referred user уже member
/// tenant'а ссылки) → статус `REJECTED`, reward не начисляется.
///
/// `referralCode` денормализован сюда же как snapshot — даже если
/// `ReferralLink` потом удалят, attribution остаётся читаемой для аудита.
model ReferralAttribution {
  id                 String                    @id @default(uuid())

  referralLinkId     String?
  referralLink       ReferralLink?             @relation(fields: [referralLinkId], references: [id], onDelete: SetNull)

  /// Snapshot кода (на случай удаления ссылки).
  referralCode       String                    @db.VarChar(32)

  /// Зафиксированный пользователь — UNIQUE: один user — одна attribution
  /// (защита от перезаписи при повторных регистрациях).
  referredUserId     String                    @unique
  referredUser       User                      @relation("ReferralReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  /// Tenant этого пользователя. UNIQUE — §13 attribution lock; NULL до
  /// шага tenant creation.
  referredTenantId   String?                   @unique
  referredTenant     Tenant?                   @relation("ReferralReferredTenant", fields: [referredTenantId], references: [id], onDelete: SetNull)

  status             ReferralAttributionStatus @default(ATTRIBUTED)
  rejectionReason    String?                   @db.VarChar(64)

  // §13 attribution context — фиксируется на регистрации, переживает
  // signup flow без потери источника.
  utmSource          String?                   @db.VarChar(128)
  utmMedium          String?                   @db.VarChar(128)
  utmCampaign        String?                   @db.VarChar(128)
  utmContent         String?                   @db.VarChar(128)
  utmTerm            String?                   @db.VarChar(128)
  sourceIp           String?                   @db.VarChar(64)
  userAgent          String?                   @db.VarChar(512)

  registrationAttributedAt DateTime            @default(now())
  tenantLockedAt           DateTime?
  firstPaidAt              DateTime?

  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  // §6 + §19: фильтрация по статусу для referral funnel dashboards.
  @@index([referralLinkId, status])
  @@index([status, registrationAttributedAt])
  // TASK_REFERRALS_5: fraud-rule queries по IP + времени.
  @@index([sourceIp, registrationAttributedAt])
}

/// Бонусный кошелёк владельца (TASK_REFERRALS_2). Один кошелёк на owner.
/// `balance` — материализованный агрегат леджера `BonusTransaction`. Он
/// обновляется атомарно (в одной DB-транзакции) вместе с записью в леджер,
/// чтобы не требовать SUM-пересчёта при каждом GET /bonus-balance.
///
/// Прямой UPDATE balance без создания BonusTransaction запрещён на уровне
/// сервиса — только `credit` и `debit`, которые всегда пишут в леджер.
model BonusWallet {
  id          String   @id @default(uuid())
  ownerUserId String   @unique
  ownerUser   User     @relation("BonusWalletOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions BonusTransaction[]
}

/// Append-only леджер бонусных операций (TASK_REFERRALS_2).
///
/// `UNIQUE(walletId, reasonCode, referredTenantId)` — идемпотентность
/// reward credit: одному referred tenant соответствует не более одного
/// credit с тем же reasonCode. PostgreSQL обрабатывает NULL как DISTINCT,
/// поэтому для операций без referredTenantId (debit за подписку) несколько
/// строк с NULL разрешены.
///
/// `reasonCode` — машинный код операции:
///   REFERRAL_REWARD   — reward credit за первый платёж реферала (TASK_REFERRALS_4);
///   BONUS_SPEND       — списание на оплату подписки (TASK_REFERRALS_3);
///   SUPPORT_CREDIT    — ручное зачисление support (через audit-only путь).
model BonusTransaction {
  id               String               @id @default(uuid())
  walletId         String
  wallet           BonusWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type             BonusTransactionType
  amount           Decimal              @db.Decimal(12, 2)
  reasonCode       String               @db.VarChar(64)
  referredTenantId String?              @db.VarChar(36)
  metadata         Json?
  createdAt        DateTime             @default(now())

  // §8 идемпотентность reward credit: (wallet, reasonCode, referredTenant) → UNIQUE.
  // NULL-referredTenantId = manual/spend операции (несколько разрешены).
  @@unique([walletId, reasonCode, referredTenantId])
  @@index([walletId, createdAt])
}

// -------------------------------------------------------------------
// 15. NOTIFICATIONS enums (TASK_NOTIFICATIONS_1)
// -------------------------------------------------------------------

// Доменная категория события (§13 system-analytics). AUTH/BILLING/SYSTEM —
// mandatory; остальные — управляемые preferences.
enum NotificationCategory {
  AUTH
  BILLING
  SYNC
  INVENTORY
  REFERRAL
  SYSTEM
}

// Канал доставки. MVP: EMAIL + IN_APP; TELEGRAM/MAX — future-ready.
enum NotificationChannel {
  EMAIL
  IN_APP
  TELEGRAM
  MAX
}

// Уровень важности события. CRITICAL включает mandatory protection
// (preferences не могут заглушить).
enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

// Политика доставки. DIGEST не входит в MVP (§22 confirmed decisions),
// но enum определён заранее как future-compatible.
enum NotificationDispatchPolicy {
  INSTANT
  DIGEST
  SCHEDULED
  THROTTLED
}

// Жизненный цикл dispatch-задачи по каналу.
// SKIPPED — событие было заглушено dedup/preferences без ошибки.
enum NotificationDispatchStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

// ─────────────────────────────────────────────────────────────────────
// Промокоды (TASK_REFERRALS_4) — §8/§14 system-analytics.
//
// Логика:
//   - `applicablePlanCodes` пуст → промокод применим ко всем планам.
//   - `maxUses` NULL → без глобального лимита использований.
//   - `stackPolicy = EXCLUSIVE` (MVP default) → нельзя комбинировать
//     с бонусным балансом в одном checkout (§14 stack rule).
//   - Идемпотентность apply: PromoRedemption UNIQUE(promoId, tenantId)
//     гарантирует, что один tenant не применит один промокод дважды.
// ─────────────────────────────────────────────────────────────────────

model PromoCode {
  id                  String           @id @default(uuid())
  code                String           @unique @db.VarChar(32)
  discountType        DiscountType
  discountValue       Decimal          @db.Decimal(12, 2)
  stackPolicy         PromoStackPolicy @default(EXCLUSIVE)
  applicablePlanCodes String[]
  maxUses             Int?
  usedCount           Int              @default(0)
  expiresAt           DateTime?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  redemptions PromoRedemption[]
}

// -------------------------------------------------------------------
// 15. NOTIFICATIONS data model (TASK_NOTIFICATIONS_1)
// -------------------------------------------------------------------

/// Источник уведомления — доменное событие, опубликованное внутренним
/// модулем. `category` и `severity` определяют mandatory policy и приоритет
/// delivery. `is_mandatory=true` защищает событие от подавления
/// preferences пользователя (§22 confirmed decisions + §4 сценарий 4).
///
/// `dedup_key` — опциональный ключ дедупликации в формате
/// `<category>:<event_type>:<entity_id>` (например,
/// `SYNC:RUN_FAILED:acc_xxx`). Вместе с tenant_id формирует окно
/// дедупликации (§10 — 15 мин по умолчанию).
///
/// `payload` — произвольный контекст доменного модуля; не показывается
/// пользователю напрямую, используется workers для форматирования
/// сообщений (§9 step 2).
model NotificationEvent {
  id         String                 @id @default(uuid())
  tenantId   String
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  category    NotificationCategory
  severity    NotificationSeverity  @default(INFO)
  isMandatory Boolean               @default(false)

  dedup_key   String?               @db.VarChar(128)

  payload     Json?

  createdAt   DateTime              @default(now())

  dispatches  NotificationDispatch[]

  // §10 dedup window: быстрый поиск дублей по (tenant, category, dedup_key).
  @@index([tenantId, category, createdAt])
  @@index([tenantId, dedup_key, createdAt])
}

/// Задача доставки для одного канала (один event → N dispatch по каналам).
/// `policy` определяет способ и время доставки; `status` отражает
/// текущий lifecycle от QUEUED до DELIVERED/FAILED/SKIPPED.
///
/// `attempts` и `lastError` поддерживают retry с backoff (§15 async).
/// `scheduledAt` — запланированное время для SCHEDULED/THROTTLED policy.
/// `sentAt` / `deliveredAt` — временны́е метки для SLA диагностики (§18).
model NotificationDispatch {
  id        String                       @id @default(uuid())
  eventId   String
  event     NotificationEvent            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  channel   NotificationChannel
  policy    NotificationDispatchPolicy   @default(INSTANT)
  status    NotificationDispatchStatus   @default(QUEUED)

  attempts    Int      @default(0)
  lastError   String?

  scheduledAt DateTime? @db.Timestamptz(6)
  sentAt      DateTime? @db.Timestamptz(6)
  deliveredAt DateTime? @db.Timestamptz(6)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Worker queue: все QUEUED задачи по каналу, отсортированные по времени.
  @@index([channel, status, createdAt])
  // Диагностика retry storm: dispatches с ошибками по event'у.
  @@index([eventId, status])
}

/// Настройки уведомлений на уровне tenant (owner-managed).
/// `channels` — JSONB: `{"email": true, "in_app": true, "telegram": false, "max": false}`.
/// `categories` — JSONB: `{"sync": true, "billing": true, "inventory": false}`.
/// `primaryChannel` — предпочтительный канал для неmandatory событий.
///
/// §10 правило: preferences не могут выключить AUTH/BILLING/SYSTEM
/// mandatory alerts на всех каналах одновременно — enforcement на уровне
/// service/orchestrator, а не в БД (§20 риск).
///
/// `timezone` денормализован из TenantSettings для delivery scheduling
/// без join'а (§18 SCHEDULED policy).
model NotificationPreferences {
  tenantId       String              @id
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  channels       Json                @default("{\"email\": true, \"in_app\": true, \"telegram\": false, \"max\": false}")
  categories     Json                @default("{\"auth\": true, \"billing\": true, \"sync\": true, \"inventory\": true, \"referral\": true, \"system\": true}")
  primaryChannel NotificationChannel @default(IN_APP)

  // digest_time зарезервирован для будущего DIGEST policy (§22: не входит в MVP).
  digestTime     String?             @db.VarChar(8)
  timezone       String?             @db.VarChar(64)

  updatedAt      DateTime            @updatedAt
}

/// In-app inbox — личный ящик уведомлений пользователя внутри продукта.
/// Создаётся worker'ом для канала IN_APP (§9 step 6).
///
/// `isRead` + `readAt` поддерживают UX read/unread и аналитику
/// notification engagement (§7 frontend behaviour).
///
/// `tenantId` денормализован рядом с `userId` для row-level tenant
/// isolation при multi-tenant queries без join через User.
model NotificationInbox {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  message   String

  isRead    Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  // Inbox feed: последние непрочитанные per (tenant, user).
  @@index([tenantId, userId, isRead, createdAt])
  // Bulk mark-read по tenant (например, "пометить всё прочитанным").
  @@index([userId, isRead])
}

/// Факт применения промокода конкретным tenant'ом в checkout.
/// UNIQUE(promoId, tenantId) — один tenant не может применить
/// один промокод дважды (идемпотентность apply).
model PromoRedemption {
  id        String    @id @default(uuid())
  promoId   String
  promo     PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  tenantId  String
  appliedAt DateTime  @default(now())

  @@unique([promoId, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────
// Referral Audit Log (TASK_REFERRALS_5) — §19 observability.
//
// Персистентный audit trail для:
//   - attribution decisions (captured / locked / rejected / fraud_review);
//   - reward credit/skip events;
//   - promo apply/reject events;
//   - fraud recheck результаты.
//
// Fire-and-forget: ошибки записи не прерывают основной flow.
// ─────────────────────────────────────────────────────────────────────
model ReferralAuditLog {
  id            String                 @id @default(uuid())
  eventType     ReferralAuditEventType
  attributionId String?
  actorId       String?
  tenantId      String?
  ruleId        String?                @db.VarChar(64)
  data          Json?
  createdAt     DateTime               @default(now())

  // §19: быстрый поиск аудит-событий по attribution, типу и tenant.
  @@index([attributionId])
  @@index([eventType, createdAt])
  @@index([tenantId])
}


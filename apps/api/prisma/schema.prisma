generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaxSystem {
  USN_6
  USN_15
  OSNO
  NPD
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum AccessState {
  EARLY_ACCESS
  TRIAL_ACTIVE
  TRIAL_EXPIRED
  ACTIVE_PAID
  SUSPENDED
  CLOSED
}

enum MarketplaceType {
  WB
  OZON
}

enum ActionType {
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STOCK_ADJUSTED
  ORDER_DEDUCTED
}

// -------------------------------------------------------------------
// 1. КОМПАНИЯ (TENANT) И ПОЛЬЗОВАТЕЛИ
// -------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessState AccessState @default(EARLY_ACCESS)

  // Налоговые настройки (сохранены из прошлой версии)
  taxSystem            TaxSystem @default(USN_6)
  vatThresholdExceeded Boolean   @default(false)

  // Связи с базовыми сущностями
  memberships         Membership[]
  marketplaceAccounts MarketplaceAccount[]

  products  Product[]
  orders    MarketplaceOrder[]
  auditLogs AuditLog[]
  reports   MarketplaceReport[]
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  telegramId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditLogs   AuditLog[] // Инициатор изменения в аудите
}

model Membership {
  id   String @id @default(uuid())
  role Role   @default(MANAGER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenantId]) // Пользователь имеет только 1 роль в 1 проекте
}

// -------------------------------------------------------------------
// 2. ИНТЕГРАЦИИ
// -------------------------------------------------------------------

model MarketplaceAccount {
  id          String          @id @default(uuid())
  name        String // Внутреннее название (псевдоним, например "Ромашка WB")
  marketplace MarketplaceType

  // Ключи доступа API
  clientId    String?
  apiKey      String?
  statApiKey  String?
  warehouseId String? // Основной Warehouse Id из кабинета

  // Диагностика синхронизации
  lastSyncAt     DateTime?
  lastSyncStatus String? // "SUCCESS" / "ERROR"
  lastSyncError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------------
// 3. БИЗНЕС СУЩНОСТИ (ТОВАРЫ, ЗАКАЗЫ)
// -------------------------------------------------------------------

model Product {
  id       String  @id @default(uuid())
  sku      String
  name     String
  photo    String?
  total    Int     @default(0)
  reserved Int     @default(0)

  // Информация для юнит-экономики
  purchasePrice  Float? @default(0)
  minPrice       Float?
  vatRate        Int    @default(0)
  commissionRate Float?
  logisticsCost  Float?

  category String?
  width    Float?
  height   Float?
  length   Float?
  weight   Float?

  rating    Float?  @default(0)
  wbBarcode String?

  // Остатки, скачанные с маркетплейсов
  ozonFbs Int @default(0)
  ozonFbo Int @default(0)
  wbFbs   Int @default(0)
  wbFbo   Int @default(0)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@unique([tenantId, wbBarcode])
}

model MarketplaceOrder {
  id                 String          @id @default(uuid())
  marketplaceOrderId String
  marketplace        MarketplaceType
  productSku         String?
  productNames       String?
  quantity           Int

  status               String?
  totalAmount          Float?
  sellerPrice          Float?
  currency             String?   @default("RUB")
  shipmentDate         DateTime?
  marketplaceCreatedAt DateTime?
  deliveryMethod       String?

  region String?
  city   String?

  createdAt   DateTime @default(now())
  processedAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, marketplaceOrderId])
}

model MarketplaceReport {
  id          String          @id @default(uuid())
  reportId    String
  marketplace MarketplaceType
  periodStart DateTime
  periodEnd   DateTime

  salesAmount      Float @default(0)
  returnsAmount    Float @default(0)
  commissionAmount Float @default(0)
  logisticsAmount  Float @default(0)
  storageAmount    Float @default(0)
  otherDeductions  Float @default(0)
  netToPay         Float @default(0)

  rawJson String?

  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reportId])
}

model AuditLog {
  id         String     @id @default(uuid())
  actionType ActionType
  createdAt  DateTime   @default(now())

  productId  String?
  productSku String?

  beforeTotal Int?
  afterTotal  Int?
  delta       Int?

  beforeName String?
  afterName  String?

  // Привязка к физическому юзеру, сделавшему изменение
  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id])
  note        String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

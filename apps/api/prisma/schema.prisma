// Sync run lifecycle (см. 09-sync §8/§13).
// Статусы покрывают весь жизненный цикл от постановки в очередь до
// завершения, включая отдельные `BLOCKED` (policy/preflight отказ) и
// `CANCELLED` (явная отмена) — они НЕ являются `FAILED`, чтобы support и
// пользователь могли отделить интеграционные инциденты от продуктовой
// блокировки.
enum SyncRunStatus {
  QUEUED
  IN_PROGRESS
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  BLOCKED
  CANCELLED
}

enum SyncTriggerType {
  MANUAL
  SCHEDULED
  RETRY
}

enum SyncTriggerScope {
  ACCOUNT
  TENANT_FULL
}

// Тип элемента, обрабатываемого в рамках run (только для проблемных
// записей — успехи в MVP агрегируются на уровне run, см. §8/§12).
enum SyncRunItemType {
  STOCK
  ORDER
  PRODUCT
  WAREHOUSE
}

// Этап pipeline, на котором произошёл item-level результат (см. §9).
enum SyncRunItemStage {
  PREFLIGHT
  PULL
  TRANSFORM
  APPLY
  PUSH
}

// Item-level статус. В MVP создаётся ТОЛЬКО для FAILED/SKIPPED/CONFLICT/
// BLOCKED (правило §8: success path хранится агрегатами в `SyncRun`).
// SUCCESS оставлен в enum как future-compatible значение.
enum SyncRunItemStatus {
  SUCCESS
  FAILED
  SKIPPED
  CONFLICT
  BLOCKED
}

// -------------------------------------------------------------------
// Orders (TASK_ORDERS_1) — см. 10-orders system-analytics §8/§13/§15.
// -------------------------------------------------------------------

// FBS / FBO. Дублирует значения InventoryFulfillmentMode/WarehouseType,
// но изолированный enum защищает orders domain от случайной семантической
// сцепки с inventory enum'ами при будущих изменениях (например, hybrid
// модели у Yandex Market).
enum OrderFulfillmentMode {
  FBS
  FBO
}

// Внутренний lifecycle заказа. В MVP business-critical для FBS только
// RESERVED / CANCELLED / FULFILLED — внешние PACKED/SHIPPED остаются в
// `externalStatus` и НЕ создают отдельный внутренний переход (§13 MVP
// правило). DISPLAY_ONLY_FBO — для FBO заказов, которые показываем без
// stock-effect. UNRESOLVED — для случаев, когда SKU не сматчен или
// warehouse scope неопределён, и мы намеренно не запускаем reserve
// "в никуда" (§9 шаг 8, §14).
enum OrderInternalStatus {
  IMPORTED
  RESERVED
  CANCELLED
  FULFILLED
  DISPLAY_ONLY_FBO
  UNRESOLVED
}

// Состояние применения inventory side-effect для заказа. Отделено от
// internal_status, потому что заказ может быть RESERVED логически, но
// stock-effect ещё PENDING/FAILED (§9 шаг 8). NOT_REQUIRED — для FBO,
// где `affectsStock=false`. BLOCKED — отказ по tenant/account state
// (§4 сценарий 4, §10).
enum OrderStockEffectStatus {
  NOT_REQUIRED
  PENDING
  APPLIED
  BLOCKED
  FAILED
}

// Статус матчинга order item на наш каталог (по SKU / channel mapping).
// UNMATCHED item сохраняется в заказе, но не участвует в stock-effect,
// пока не будет resolved (§14).
enum OrderItemMatchStatus {
  MATCHED
  UNMATCHED
}

// Тип события в order timeline. Покрывает provenance (RECEIVED), маппинг
// статусов (STATUS_CHANGED), inventory side-effects (RESERVED/RELEASED/
// DEDUCTED), idempotency-диагностику (DUPLICATE_IGNORED, OUT_OF_ORDER_
// IGNORED) и failure диагностику (STOCK_EFFECT_FAILED). См. §15.
enum OrderEventType {
  RECEIVED
  STATUS_CHANGED
  RESERVED
  RESERVE_RELEASED
  DEDUCTED
  RETURN_LOGGED
  DUPLICATE_IGNORED
  OUT_OF_ORDER_IGNORED
  STOCK_EFFECT_FAILED
}

// -------------------------------------------------------------------
// Finance / Unit Economics (TASK_FINANCE_1) — см. 11-finance system-
// analytics §8/§13/§14.
// -------------------------------------------------------------------

// Тип периода для finance snapshot. `WEEK`/`MONTH` — детерминированные
// календарные окна (для nightly job), `CUSTOM` — произвольный
// from/to для on-demand rebuild owner/admin'а (§4 сценарий 2).
enum FinanceSnapshotPeriodType {
  WEEK
  MONTH
  CUSTOM
}

// Состояние сгенерированного snapshot. `INCOMPLETE` отделён от `READY`
// и `FAILED` сознательно: расчёт прошёл, но критичные source отсутствуют
// (см. §14 правило неполного расчёта). Это НЕ ошибка — данные показываем
// с warning, а не молчаливыми нулями (§20 риск).
enum FinanceSnapshotStatus {
  READY
  INCOMPLETE
  FAILED
}

// Типы предупреждений о неполных данных (§13 правило источников истины,
// §14 MVP правило обязательных cost components). Стабильный enum —
// потому что UI рендерит их человекочитаемыми объяснениями и
// фильтрует /api/v1/finance/warnings по типу.
//
// `MISSING_COST` / `MISSING_FEES` / `MISSING_LOGISTICS` — критичные
// для MVP компоненты (§14): отсутствие → `INCOMPLETE` snapshot.
// `MISSING_TAX` / `MISSING_ADS_COST` / `MISSING_RETURNS_DATA` — optional/
// improving inputs: создают warning, но не блокируют расчёт.
// `STALE_FINANCIAL_SOURCE` — отдельный тип для §14 правила stale
// snapshot (источники не обновлялись дольше допустимого окна).
enum FinanceWarningType {
  MISSING_COST
  MISSING_FEES
  MISSING_LOGISTICS
  MISSING_TAX
  MISSING_ADS_COST
  MISSING_RETURNS_DATA
  STALE_FINANCIAL_SOURCE
}

// -------------------------------------------------------------------
// Analytics / Sales Insight (TASK_ANALYTICS_1) — см. 12-analytics
// system-analytics §8/§13/§14.
// -------------------------------------------------------------------

// Метрика, по которой строится ABC-классификация. В MVP §14 правило —
// `REVENUE_NET`, чтобы не смешивать gross-выручку с ещё не снятыми
// удержаниями/возвратным шумом. `UNITS` — для будущего расширения
// drill-down по штучной популярности.
enum AnalyticsAbcMetric {
  REVENUE_NET
  UNITS
}

// Состояние снапшота analytics-витрины. `STALE` отделён от `INCOMPLETE`
// сознательно (§19 stale-vs-incomplete board): STALE — источник перестал
// обновляться, но расчёт корректен; INCOMPLETE — источник свежий, но
// часть компонентов отсутствует. Оба состояния одновременно представимы
// в UI, поэтому хранятся раздельно. `FAILED` — pipeline упал, payload
// недоступен.
enum AnalyticsSnapshotStatus {
  READY
  STALE
  INCOMPLETE
  FAILED
}

// Приоритет рекомендации. Стабильный enum — UI рендерит цветовой бейдж
// и сортировку. `HIGH` — низкий остаток + высокий спрос; `MEDIUM` —
// деградация рейтинга/рост возвратов; `LOW` — фоновые подсказки.
enum AnalyticsRecommendationPriority {
  LOW
  MEDIUM
  HIGH
}

// Жизненный цикл рекомендации. В MVP §15 правило — рекомендации остаются
// `ACTIVE` (read-only); `DISMISSED` / `APPLIED` зарезервированы под
// будущий пользовательский workflow и пока выставляются только rule
// engine'ом при автоматическом устаревании сигнала.
enum AnalyticsRecommendationStatus {
  ACTIVE
  DISMISSED
  APPLIED
}

// -------------------------------------------------------------------
// Referrals (TASK_REFERRALS_1 + TASK_REFERRALS_2) — см. 14-referrals system-analytics §8/§13.
// -------------------------------------------------------------------

// Тип операции в бонусном леджере (TASK_REFERRALS_2).
//   CREDIT — зачисление (referral reward, ручная корректировка support).
//   DEBIT  — списание (оплата подписки с применением бонусов, TASK_REFERRALS_3).
enum BonusTransactionType {
  CREDIT
  DEBIT
}

// Жизненный цикл referral attribution (§9 + §10).
//   - ATTRIBUTED — context зафиксирован при регистрации, но tenant ещё
//     не создан. Промежуточное состояние, не даёт reward.
//   - PAID — tenant создан, прошла первая успешная оплата (TASK_REFERRALS_4
//     billing trigger). Готов к credit, но reward ещё не выдан.
//   - REWARDED — bonus credit зачислен (TASK_REFERRALS_4); идемпотентно
//     терминальное состояние.
//   - REJECTED — self-referral / fraud / invalid: reward никогда не будет.
//   - FRAUD_REVIEW — спорный кейс на ручной разбор (TASK_REFERRALS_5).
enum ReferralAttributionStatus {
  ATTRIBUTED
  PAID
  REWARDED
  REJECTED
  FRAUD_REVIEW
}

// Промокоды (TASK_REFERRALS_4) — тип скидки и stack policy.
enum DiscountType {
  PERCENT
  FIXED
}

// MVP stack rule §14: промокод и бонусный баланс взаимно исключаемы (EXCLUSIVE).
// COMBINABLE_WITH_BONUS зарезервирован для будущих кампаний.
enum PromoStackPolicy {
  EXCLUSIVE
  COMBINABLE_WITH_BONUS
}

// Типы событий в audit-логе рефералов (TASK_REFERRALS_5).
enum ReferralAuditEventType {
  ATTRIBUTION_CAPTURED
  ATTRIBUTION_LOCKED
  ATTRIBUTION_REJECTED
  ATTRIBUTION_FRAUD_REVIEW
  REWARD_CREDITED
  REWARD_SKIPPED
  PROMO_APPLIED
  PROMO_REJECTED
  FRAUD_RECHECK_COMPLETED
}

// -------------------------------------------------------------------
// 1. ПОЛЬЗОВАТЕЛИ И AUTH
// -------------------------------------------------------------------

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // Telegram — временно остаётся здесь, будет вынесено в AuthIdentity
  telegramId String? @unique

  // Инкрементируется при любом изменении состава memberships;
  // JWT использует его для валидации кешированного activeTenantId.
  membershipVersion Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships                    Membership[]
  auditLogs                      AuditLog[]
  securityEvents                 SecurityEvent[]
  authSessions                   AuthSession[]
  emailVerifications             EmailVerificationChallenge[]
  passwordResets                 PasswordResetChallenge[]
  preferences                    UserPreference?
  authIdentities                 AuthIdentity[]
  ownedTenants                   Tenant[]                     @relation("TenantPrimaryOwner")
  sentInvitations                Invitation[]                 @relation("InvitationSentBy")
  acceptedInvitations            Invitation[]                 @relation("InvitationAcceptedBy")
  teamEvents                     TeamEvent[]                  @relation("TeamEventActor")
  onboardingStates               OnboardingState[]
  createdProducts                Product[]                    @relation("ProductCreatedBy")
  updatedProducts                Product[]                    @relation("ProductUpdatedBy")
  createdMappings                ProductChannelMapping[]      @relation("MappingCreatedBy")
  createdImportJobs              CatalogImportJob[]           @relation("ImportJobCreatedBy")
  stockMovements                 StockMovement[]              @relation("StockMovementActor")
  warehouseMetadataUpdates       Warehouse[]                  @relation("WarehouseMetadataUpdatedBy")
  deactivatedMarketplaceAccounts MarketplaceAccount[]         @relation("MarketplaceAccountDeactivatedBy")
  updatedFinanceProfiles         ProductFinanceProfile[]      @relation("FinanceProfileUpdatedBy")
  generatedFinanceSnapshots      FinanceSnapshot[]            @relation("FinanceSnapshotGeneratedBy")
  ownedReferralLinks             ReferralLink[]               @relation("ReferralLinkOwner")
  referralAttributionsAsReferred ReferralAttribution[]        @relation("ReferralReferredUser")
  bonusWallet                    BonusWallet?                 @relation("BonusWalletOwner")
  notificationInboxItems         NotificationInbox[]
}

// Серверные сессии с refresh token rotation и reuse detection
model AuthSession {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String            @unique
  status           AuthSessionStatus @default(ACTIVE)
  ip               String?
  userAgent        String?
  lastSeenAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, status])
}

// Одноразовые токены подтверждения email (хранится hash, не plaintext)
model EmailVerificationChallenge {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailSnapshot String
  tokenHash     String          @unique
  status        ChallengeStatus @default(PENDING)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
}

// Одноразовые токены сброса пароля (хранится hash, не plaintext)
model PasswordResetChallenge {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String          @unique
  status    ChallengeStatus @default(PENDING)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

// Пользовательские настройки — последний активный тенант
model UserPreference {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedTenantId String?
  locale           String?
  timezone         String?
  updatedAt        DateTime @updatedAt
}

// Неудачные попытки входа — для soft-lock по паре (email + IP)
model LoginAttempt {
  id              String   @id @default(uuid())
  normalizedEmail String
  ip              String
  createdAt       DateTime @default(now())

  @@index([normalizedEmail, ip, createdAt])
}

// Identity-провайдеры (future-ready: OAuth, SMS)
model AuthIdentity {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        AuthProvider
  providerSubject String?
  isPrimary       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerSubject])
  @@index([userId])
}

// -------------------------------------------------------------------
// 2. КОМПАНИЯ (TENANT) И КОМАНДА
// -------------------------------------------------------------------

model Tenant {
  id          String       @id @default(uuid())
  name        String
  inn         String?
  status      TenantStatus @default(ACTIVE)
  accessState AccessState  @default(EARLY_ACCESS)

  primaryOwnerUserId String?
  primaryOwner       User?   @relation("TenantPrimaryOwner", fields: [primaryOwnerUserId], references: [id], onDelete: SetNull)

  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  settings          TenantSettings?
  accessStateEvents TenantAccessStateEvent[]
  closureJob        TenantClosureJob?

  memberships              Membership[]
  marketplaceAccounts      MarketplaceAccount[]
  products                 Product[]
  orders                   MarketplaceOrder[]
  auditLogs                AuditLog[]
  securityEvents           SecurityEvent[]
  reports                  MarketplaceReport[]
  invitations              Invitation[]
  teamEvents               TeamEvent[]
  onboardingStates         OnboardingState[]
  channelMappings          ProductChannelMapping[]
  importJobs               CatalogImportJob[]
  stockBalances            StockBalance[]
  stockMovements           StockMovement[]
  inventoryEffectLocks     InventoryEffectLock[]
  inventorySettings        InventorySettings?
  warehouses               Warehouse[]
  marketplaceAccountEvents MarketplaceAccountEvent[]
  syncRuns                 SyncRun[]
  syncConflicts            SyncConflict[]
  domainOrders             Order[]
  orderEvents              OrderEvent[]
  productFinanceProfiles   ProductFinanceProfile[]
  financeSnapshots         FinanceSnapshot[]
  financeDataWarnings      FinanceDataWarning[]
  analyticsDailyMetrics    AnalyticsMaterializedDaily[]
  analyticsAbcSnapshots    AnalyticsAbcSnapshot[]
  analyticsRecommendations AnalyticsRecommendation[]
  referralLinks            ReferralLink[]
  referralAttributions     ReferralAttribution[]      @relation("ReferralReferredTenant")
  notificationEvents       NotificationEvent[]
  notificationPreferences  NotificationPreferences?
  notificationInboxItems   NotificationInbox[]
}

// Настройки компании, вынесены из Tenant для чистоты модели
model TenantSettings {
  tenantId             String    @id
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  taxSystem            TaxSystem @default(USN_6)
  vatThresholdExceeded Boolean   @default(false)
  country              String?
  currency             String?
  timezone             String?
  legalName            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// История переходов AccessState — audit trail каждого изменения
model TenantAccessStateEvent {
  id            String          @id @default(uuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromState     AccessState?
  toState       AccessState
  reasonCode    String
  reasonDetails Json?
  actorType     TenantActorType
  actorId       String?
  createdAt     DateTime        @default(now())

  @@index([tenantId, createdAt])
}

// Задача на retention/archival после закрытия tenant
model TenantClosureJob {
  id            String                 @id @default(uuid())
  tenantId      String                 @unique
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status        TenantClosureJobStatus @default(PENDING)
  scheduledFor  DateTime
  processedAt   DateTime?
  failureReason String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model Membership {
  id     String           @id @default(uuid())
  role   Role             @default(MANAGER)
  status MembershipStatus @default(ACTIVE)

  joinedAt  DateTime?
  revokedAt DateTime?
  leftAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([tenantId, status])
}

model Invitation {
  id     String           @id @default(uuid())
  email  String
  role   Role
  status InvitationStatus @default(PENDING)

  tokenHash String @unique

  expiresAt   DateTime
  acceptedAt  DateTime?
  cancelledAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User   @relation("InvitationSentBy", fields: [invitedByUserId], references: [id])

  acceptedByUserId String?
  acceptedBy       User?   @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tokenHash])
}

model TeamEvent {
  id        String @id @default(uuid())
  eventType String
  payload   Json?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  actorUserId String?
  actor       User?   @relation("TeamEventActor", fields: [actorUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// -------------------------------------------------------------------
// 3. ИНТЕГРАЦИИ
// -------------------------------------------------------------------

model MarketplaceAccount {
  id          String          @id @default(uuid())
  name        String
  marketplace MarketplaceType

  // Legacy plaintext credentials. НЕ удаляем в TASK_1, чтобы существующие
  // sync.service / settings.service продолжали работать. Полная миграция в
  // encrypted MarketplaceCredential — TASK_MARKETPLACE_ACCOUNTS_2/3.
  clientId    String?
  apiKey      String?
  statApiKey  String?
  warehouseId String?

  // Legacy sync indicators. Сохранены для обратной совместимости рядом с
  // новыми статусами ниже.
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?

  // ── Lifecycle (TASK_MARKETPLACE_ACCOUNTS_1) ─────────────────────────
  // Человекочитаемое имя подключения внутри (tenant, marketplace).
  // На уровне БД enforced UNIQUE(tenantId, marketplace, label).
  label String @db.VarChar(128)

  lifecycleStatus  MarketplaceLifecycleStatus  @default(ACTIVE)
  credentialStatus MarketplaceCredentialStatus @default(UNKNOWN)
  syncHealthStatus MarketplaceSyncHealthStatus @default(UNKNOWN)
  syncHealthReason String?                     @db.VarChar(64)

  lastValidatedAt            DateTime?
  lastValidationErrorCode    String?   @db.VarChar(64)
  lastValidationErrorMessage String?

  // Новый enum-based result для sync, не конфликтует с legacy String.
  lastSyncResult       MarketplaceLastSyncStatus?
  lastSyncErrorCode    String?                    @db.VarChar(64)
  lastSyncErrorMessage String?

  deactivatedAt     DateTime?
  deactivatedBy     String?
  deactivatedByUser User?     @relation("MarketplaceAccountDeactivatedBy", fields: [deactivatedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  warehouses  Warehouse[]
  credential  MarketplaceCredential?
  events      MarketplaceAccountEvent[]
  syncRuns    SyncRun[]
  orders      Order[]
  orderEvents OrderEvent[]

  @@unique([tenantId, marketplace, label])
  @@index([tenantId, lifecycleStatus])
  @@index([tenantId, credentialStatus])
  @@index([tenantId, syncHealthStatus])
}

/// Шифрованное хранилище credentials (1:1 c MarketplaceAccount).
/// `encryptedPayload` — opaque ciphertext, расшифровывается только в
/// adapter-слое sync. `maskedPreview` JSONB содержит безопасные «хвосты»
/// для UI (например, `{ "apiKey": "***xxxx", "warehouseId": "1234" }`).
/// `encryptionKeyVersion` и `schemaVersion` поддерживают rotation/migration.
model MarketplaceCredential {
  id                   String             @id @default(uuid())
  accountId            String             @unique
  account              MarketplaceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  encryptedPayload     Bytes
  encryptionKeyVersion Int
  schemaVersion        Int                @default(1)
  maskedPreview        Json?
  rotatedAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

/// Append-only журнал событий жизненного цикла подключения (см. §15
/// system-analytics: created/validated/deactivated/credentials_rotated и т.д.).
model MarketplaceAccountEvent {
  id        String             @id @default(uuid())
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId String
  account   MarketplaceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  eventType String             @db.VarChar(64)
  payload   Json?
  createdAt DateTime           @default(now())

  @@index([tenantId, accountId, createdAt])
  @@index([tenantId, eventType, createdAt])
}

// -------------------------------------------------------------------
// 3b. SYNC RUN REGISTRY (TASK_SYNC_1)
// -------------------------------------------------------------------

/// Run registry синхронизации (см. 09-sync §8/§9/§13). Хранит lifecycle
/// каждого manual/scheduled/retry запуска: postановку в очередь, preflight,
/// blocked/cancelled, агрегированные счётчики и финальный результат.
///
/// `marketplaceAccountId` nullable, чтобы поддержать `tenant_full` scope
/// (run, охватывающий все аккаунты сразу — future-only по §10/§13, но
/// схема готова заранее). Удаление аккаунта переводит ссылку в NULL и не
/// ломает историю run'ов.
///
/// `originRunId` — self-relation для retry-цепочек. `jobKey`/`idempotencyKey`
/// обеспечивают дедупликацию входящих job'ов на стороне worker (см. §14).
///
/// Правило MVP §8: success path хранится агрегатами здесь
/// (`processedCount`/`errorCount`/`durationMs`), а не полным item-level
/// логом — `SyncRunItem` создаётся ТОЛЬКО для проблемных кейсов.
model SyncRun {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  marketplaceAccountId String?
  marketplaceAccount   MarketplaceAccount? @relation(fields: [marketplaceAccountId], references: [id], onDelete: SetNull)

  triggerType  SyncTriggerType
  triggerScope SyncTriggerScope @default(ACCOUNT)

  /// Допустимые значения: PULL_STOCKS, PUSH_STOCKS, PULL_ORDERS, PULL_METADATA, FULL_SYNC.
  /// TEXT[] (а не enum[]) — расширение списка не должно требовать миграции
  /// БД. Валидируется на application слое через SyncTypes константу.
  syncTypes String[] @default([])

  status SyncRunStatus @default(QUEUED)

  // Retry chain: новый run с triggerType=RETRY ссылается на свой источник.
  originRunId String?
  originRun   SyncRun?  @relation("SyncRunRetryChain", fields: [originRunId], references: [id], onDelete: SetNull)
  retries     SyncRun[] @relation("SyncRunRetryChain")

  // Queue / idempotency.
  jobKey         String? @db.VarChar(128)
  idempotencyKey String? @db.VarChar(128)

  requestedBy String?

  // Diagnostic причина для status=BLOCKED. Машинный код, не free-text:
  // например `TENANT_TRIAL_EXPIRED`, `TENANT_SUSPENDED`, `ACCOUNT_INACTIVE`,
  // `CREDENTIALS_INVALID`, `CONCURRENCY_GUARD`.
  blockedReason String? @db.VarChar(64)

  startedAt  DateTime?
  finishedAt DateTime?
  durationMs Int?

  // Aggregated counters (правило §8): все успехи и ошибки run'а уровня items.
  processedCount Int @default(0)
  errorCount     Int @default(0)

  // Последняя ошибка run-уровня (отдельно от item-level errors в SyncRunItem).
  errorCode    String? @db.VarChar(64)
  errorMessage String?

  // Retry policy metadata (см. §10/§14, queue contract).
  attemptNumber Int       @default(1)
  maxAttempts   Int       @default(3)
  nextAttemptAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     SyncRunItem[]
  conflicts SyncConflict[]
  orders    Order[]

  // Idempotency на уровне БД: один и тот же jobKey не попадёт в очередь дважды.
  @@unique([tenantId, jobKey])
  // UI-фильтры: список последних запусков по tenant и по конкретному аккаунту.
  @@index([tenantId, status, createdAt])
  @@index([tenantId, marketplaceAccountId, createdAt])
  @@index([originRunId])
}

/// Item-level диагностика sync run. Создаётся ТОЛЬКО для проблемных
/// результатов (failed/skipped/conflict/blocked) — success path остаётся
/// агрегированным в `SyncRun.processedCount` (см. §8/§20: иначе storage и
/// diagnostic noise растут быстрее реальной пользы).
///
/// `itemKey` — внешний идентификатор затронутой сущности (sku, posting
/// number, barcode); `externalEventId` — id события маркетплейса для
/// дедупликации (см. §14). `payload`/`error` — произвольная диагностика
/// для расследования без прямого доступа к БД.
model SyncRunItem {
  id    String  @id @default(uuid())
  runId String
  run   SyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  itemType SyncRunItemType
  itemKey  String            @db.VarChar(128)
  stage    SyncRunItemStage
  status   SyncRunItemStatus

  externalEventId String? @db.VarChar(128)
  payload         Json?
  error           Json?

  createdAt DateTime @default(now())

  @@index([runId, status])
  @@index([runId, itemType])
  @@index([runId, stage])
}

/// Реестр конфликтов sync (см. §8/§9/§19). Конфликт — это событие/данные,
/// которые нельзя безопасно применить автоматически (например, ручная
/// корректировка inventory разошлась с подтверждённым внешним заказом).
/// Run при этом не падает, а помечается `PARTIAL_SUCCESS`. `resolvedAt`
/// заполняется, когда support/пользователь явно закрыл конфликт.
model SyncConflict {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runId    String
  run      SyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  entityType   String  @db.VarChar(64)
  entityId     String? @db.VarChar(128)
  conflictType String  @db.VarChar(64)
  payload      Json?

  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  // UI: открытые конфликты по tenant.
  @@index([tenantId, resolvedAt, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([runId])
}

